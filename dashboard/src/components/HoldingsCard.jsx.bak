import { useState, useEffect, useRef } from "react"
import { getHtxBalance } from "../services/api"

export default function HoldingsCard() {
  const [holdings, setHoldings] = useState({ assets: {}, total: 0, btcPrice: 0 })
  const [isRefreshing, setIsRefreshing] = useState(false)
  const isFirstLoad = useRef(true)

  useEffect(() => {
    // Load immediately on mount
    loadHoldings()
    const interval = setInterval(loadHoldings, 30000) // Refresh every 30s
    return () => clearInterval(interval)
  }, [])

  const loadHoldings = async () => {
    try {
      setIsRefreshing(!isFirstLoad.current) // Only show refreshing indicator after first load
      isFirstLoad.current = false
      const data = await getHtxBalance()
      if (data && !data.error) {
        setHoldings({
          assets: data.assets || {},
          total: data.total_value_usdd || 0,
          btcPrice: data.btc_price || 0
        })
      }
    } catch (e) {
      console.error("Failed to load holdings:", e)
    } finally {
      setIsRefreshing(false)
    }
  }

  // Show "Updating..." badge only when refreshing after first load
  const showUpdating = isRefreshing && Object.keys(holdings.assets).length > 0

  const { assets } = holdings
  
  // Only show USDD and BTC
  const sortedAssets = Object.entries(assets)
    .filter(([asset, data]) => (asset === 'USDD' || asset === 'BTC') && data.value_usdd > 0)
    .sort((a, b) => b[1].value_usdd - a[1].value_usdd)

  // Total = sum of displayed assets only
  const displayedTotal = sortedAssets.reduce((sum, [_, data]) => sum + data.value_usdd, 0)

  // Color mapping for common assets
  const assetColors = {
    'BTC': 'bg-orange-500',
    'ETH': 'bg-purple-500',
    'USDT': 'bg-green-500',
    'USDD': 'bg-green-600',
    'TRX': 'bg-red-500',
    'ETHW': 'bg-gray-400',
    'BTT': 'bg-orange-400',
    'NFT': 'bg-pink-500',
  }

  const getColor = (asset) => assetColors[asset] || 'bg-blue-500'

  return (
    <div className="text-sm">
      <h3 className="font-semibold mb-3 text-gray-800 flex items-center gap-2">
        Your HTX Holdings
        {showUpdating && <span className="text-xs text-gray-400 animate-pulse">(Updating...)</span>}
      </h3>

      <div className="space-y-2">
        {sortedAssets.length === 0 ? (
          <div className="text-gray-500 text-center py-4">No assets found</div>
        ) : (
          sortedAssets.map(([asset, data]) => (
            <div key={asset} className="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
              <div className="flex items-center gap-2">
                <div className={`w-3 h-3 ${getColor(asset)} rounded-full`}></div>
                <span className="text-gray-700 font-medium">{asset}</span>
              </div>
              <div className="text-right">
                <div className="font-medium text-gray-900">
                  {data.total.toFixed(asset === 'USDT' || asset === 'USDD' ? 2 : 6)} {asset !== 'USDT' && asset !== 'USDD' ? '' : ''}
                </div>
                <div className="text-xs text-gray-500">
                  ≈ ${data.value_usdd.toFixed(2)}
                </div>
              </div>
            </div>
          ))
        )}
      </div>

      {/* Total */}
      <div className="flex justify-between items-center py-3 bg-gray-50 rounded-lg px-3 mt-4">
        <div className="font-semibold text-gray-800">Total Portfolio</div>
        <div className="font-bold text-lg text-gray-900">${displayedTotal.toFixed(2)}</div>
      </div>

      <p className="text-xs text-gray-400 mt-4">
        Last updated: {new Date().toLocaleTimeString()}
      </p>
    </div>
  )
}